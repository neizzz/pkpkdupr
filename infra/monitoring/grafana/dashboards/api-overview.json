{
  "title": "API Overview",
  "uid": "api-overview",
  "version": 1,
  "revision": 1,
  "schemaVersion": 39,
  "tags": ["api", "prometheus", "pkpkdupr"],
  "timezone": "Asia/Seoul",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "route",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(http_requests_total{job=\"pkpkdupr_api\"}, route)",
        "query": {
          "query": "label_values(http_requests_total{job=\"pkpkdupr_api\"}, route)",
          "refId": "routeVar"
        },
        "includeAll": true,
        "multi": false,
        "refresh": 1,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "API Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=\"pkpkdupr_api\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Rate (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"pkpkdupr_api\", route=~\"$route\"}[5m]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 3,
      "title": "In-flight Requests",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "http_requests_in_flight{job=\"pkpkdupr_api\"}",
          "legendFormat": "in-flight",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0
        }
      }
    },
    {
      "id": 4,
      "title": "4xx Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"pkpkdupr_api\", route=~\"$route\", status_code=~\"4..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"pkpkdupr_api\", route=~\"$route\"}[5m])), 0.0001)",
          "legendFormat": "4xx",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        }
      }
    },
    {
      "id": 5,
      "title": "5xx Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"pkpkdupr_api\", route=~\"$route\", status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"pkpkdupr_api\", route=~\"$route\"}[5m])), 0.0001)",
          "legendFormat": "5xx",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        }
      }
    },
    {
      "id": 6,
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"pkpkdupr_api\", route=~\"$route\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"pkpkdupr_api\", route=~\"$route\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"pkpkdupr_api\", route=~\"$route\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 7,
      "title": "Requests by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{job=\"pkpkdupr_api\", route!=\"unmatched\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 8,
      "title": "Process RSS Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"pkpkdupr_api\"}",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 9,
      "title": "Heap Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"pkpkdupr_api\"}",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=\"pkpkdupr_api\"}",
          "legendFormat": "Heap Total",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 10,
      "title": "CPU Usage Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [
        {
          "expr": "rate(process_cpu_user_seconds_total{job=\"pkpkdupr_api\"}[5m])",
          "legendFormat": "user",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_system_seconds_total{job=\"pkpkdupr_api\"}[5m])",
          "legendFormat": "system",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s/s"
        }
      }
    }
  ],
  "annotations": {
    "list": []
  }
}
